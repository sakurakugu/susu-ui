{
  "name": "susu-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @susu-ui/tokens build && pnpm --filter @susu-ui/theme build && pnpm --filter @susu-ui/vue build",
    "changeset": "changeset",
    "check": "pnpm check:components && pnpm \"/^(lint|format:check|typecheck|test)$/\" && pnpm build && pnpm check:exports",
    "check:components": "node scripts/check-component-manifest.mjs",
    "check:exports": "node scripts/check-package-exports.mjs",
    "check:fix": "pnpm format && pnpm lint:fix && pnpm format && pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm --filter playground dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "pnpm build && pnpm check:exports && changeset publish",
    "sync:components": "node scripts/sync-vue-component-manifest.mjs",
    "test": "vitest run",
    "typecheck": "pnpm -r --parallel --if-present typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.9.0"
}
