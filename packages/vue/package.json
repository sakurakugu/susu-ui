{
  "name": "@susu-ui/vue",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/susu-ui-vue.umd.cjs",
  "module": "./dist/susu-ui-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/susu-ui-vue.js",
      "require": "./dist/susu-ui-vue.umd.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@susu-ui/theme": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^6.3.5",
    "vue": "^3.5.16",
    "vue-tsc": "^2.2.10"
  }
}
