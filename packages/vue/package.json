{
  "name": "@susu-ui/vue",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/susu-ui-vue.cjs",
  "module": "./dist/susu-ui-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/susu-ui-vue.js",
      "require": "./dist/susu-ui-vue.cjs"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/button.js",
      "require": "./dist/button.cjs"
    },
    "./card": {
      "types": "./dist/components/card/index.d.ts",
      "import": "./dist/card.js",
      "require": "./dist/card.cjs"
    },
    "./divider": {
      "types": "./dist/components/divider/index.d.ts",
      "import": "./dist/divider.js",
      "require": "./dist/divider.cjs"
    },
    "./icon": {
      "types": "./dist/components/icon/index.d.ts",
      "import": "./dist/icon.js",
      "require": "./dist/icon.cjs"
    },
    "./input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/input.js",
      "require": "./dist/input.cjs"
    },
    "./message": {
      "types": "./dist/components/message/index.d.ts",
      "import": "./dist/message.js",
      "require": "./dist/message.cjs"
    },
    "./rate": {
      "types": "./dist/components/rate/index.d.ts",
      "import": "./dist/rate.js",
      "require": "./dist/rate.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@susu-ui/theme": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^6.3.5",
    "vue": "^3.5.16",
    "vue-tsc": "^2.2.10"
  }
}
